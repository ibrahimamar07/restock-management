<?xml version="1.0"?>
<ruleset name="RestockManagement">
    <description>Project PHP_CodeSniffer rules</description>

    <rule ref="PSR12" />

    <file>app</file>
    <file>routes</file>
    <file>database</file>
    <file>tests</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/storage/*</exclude-pattern>
    <exclude-pattern>*/public/*</exclude-pattern>

    <arg name="extensions" value="php" />
</ruleset>
