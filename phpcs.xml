<?xml version="1.0"?>
<ruleset name="RestockManagement">
  <description>Project coding standard — PSR12</description>
  <rule ref="PSR12"/>

  <!-- Tests use snake_case method names (PHPUnit). Do not enforce CamelCaps here. -->
  <rule ref="PSR1.Methods.CamelCapsMethodName">
    <exclude-pattern>tests/*</exclude-pattern>
  </rule>

  <file>app</file>
  <file>tests</file>
  <file>routes</file>
  <file>database</file>
  <file>config</file>

  <!-- Exclude vendor and storage -->
  <exclude-pattern>*/vendor/*</exclude-pattern>
  <exclude-pattern>*/storage/*</exclude-pattern>
</ruleset>
